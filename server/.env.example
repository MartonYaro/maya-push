PORT=3000
JWT_SECRET=change-me-in-prod-please-32chars-minimum
DB_PATH=./data/maya.db

# Public URL — used in email links. On Render set to https://app.mayapush.com
PUBLIC_URL=http://localhost:3000

# Domain split (production):
#   mayapush.com         → landing only
#   app.mayapush.com     → dashboard / product / API
APP_HOST=app.mayapush.com
MARKETING_HOST=mayapush.com

# Position data is parsed live from the public App Store (no API key needed).
POSITION_CRON=0 */6 * * *
ALLOW_ORIGIN=*

# Email — Resend HTTP API. Free tier: 100/day.
# Get key: https://resend.com/api-keys
# NOTE: while RESEND_API_KEY is empty, the app runs in PILOT MODE — new accounts
# are auto-verified (no email confirmation needed) so the cabinet works fully.
# As soon as you set RESEND_API_KEY, strict email verification turns on.
RESEND_API_KEY=
EMAIL_FROM=MAYA Push <onboarding@resend.dev>
# Force-skip email verification even when RESEND is configured (e.g. staging):
# AUTH_AUTO_VERIFY=1

# Telegram bot for admin notifications.
# Bot from @BotFather, then send any message to it and get chat_id from
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT=

# Per-user limits (override for premium customers)
MAX_APPS_PER_USER=10
MAX_KEYWORDS_PER_APP=50
MAX_INSTALLS_PER_KW_DAY=5000

# Daily DB backup
BACKUP_CRON=17 3 * * *
BACKUP_KEEP=7
# BACKUP_DIR=                 # defaults to <DB_PATH dir>/backups
