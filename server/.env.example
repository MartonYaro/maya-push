PORT=3000
JWT_SECRET=change-me-in-prod-please-32chars-minimum
DB_PATH=./data/maya.db

# Public URL — used in email links. On Render set to https://<your>.onrender.com
PUBLIC_URL=http://localhost:3000

APPTWEAK_API_KEY=
APPTWEAK_BASE_URL=https://public-api.apptweak.com
POSITION_CRON=0 */6 * * *
ALLOW_ORIGIN=*

# Email — Resend HTTP API. Free tier: 100/day.
# Get key: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=MAYA Push <onboarding@resend.dev>

# Telegram bot for admin notifications.
# Bot from @BotFather, then send any message to it and get chat_id from
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT=
